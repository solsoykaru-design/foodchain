{
  "name": "foodchain-admin",
  "version": "1.0.0",
  "description": "FoodChain Admin Panel",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "npx @electron/packager . FoodChain-Admin --platform=win32 --arch=x64 --out=dist --overwrite --prune=true"
  },
  "build": {
    "appId": "com.foodchain.admin",
    "productName": "FoodChain Admin",
    "electronDist": "node_modules/electron/dist",
    "extraResources": [
      {
        "from": "../dist-admin",
        "to": "dist-admin",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "portable",
      "icon": null
    }
  },
  "dependencies": {
    "express": "^4.22.2",
    "http-proxy-middleware": "^3.0.7"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2"
  }
}
