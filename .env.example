# ─── FoodChain Environment Configuration ───────────────────────
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control

# JWT secret keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=change-this-to-a-random-secret
SUPPLIER_JWT_SECRET=change-this-to-another-random-secret

# Shared key for portal-to-server communication
PORTAL_SYNC_KEY=change-this-to-a-portal-sync-key

# Production mode (uncomment when deploying)
# NODE_ENV=production

# Allowed CORS origins (comma-separated, no spaces)
# ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# Server port (default: 4000 — portal встроен, отдельный порт не нужен)
# PORT=4000

# Portal CORS origins (comma-separated, no spaces)
# CORS_ORIGINS=http://localhost:5180,http://localhost:4000,https://portal.foodchain.uz,https://admin.foodchain.uz

# Payme credentials (для приёма платежей от арендаторов)
# PAYME_MERCHANT_ID=your-payme-merchant-id
# PAYME_SECRET_KEY=your-payme-secret-key

# Telegram bot token (optional)
# TELEGRAM_BOT_TOKEN=

# ─── Telegram Bot ──────────────────────────────────────────
# Создайте бота через @BotFather в Telegram, скопируйте токен сюда.
# TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# TELEGRAM_NOTIFY_CHAT_ID=

# Email settings (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
